<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password Changed</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background: #f6f8fb;
      font-family: Arial, sans-serif;
      color: #0f172a;
    "
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      role="presentation"
      style="background: #f6f8fb; padding: 24px 0"
    >
      <tr>
        <td align="center">
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            role="presentation"
            style="
              max-width: 580px;
              background: #ffffff;
              border: 1px solid #e2e8f0;
              border-radius: 12px;
              overflow: hidden;
            "
          >
            <tr>
              <td
                style="padding: 24px 28px; background: #0f766e; color: #ffffff"
              >
                <h1 style="margin: 0; font-size: 22px">Password Updated</h1>
              </td>
            </tr>
            <tr>
              <td style="padding: 28px">
                <p style="margin: 0 0 12px; font-size: 15px; line-height: 1.7">
                  Hi <strong><%= name %></strong>,
                </p>
                <p
                  style="
                    margin: 0 0 14px;
                    font-size: 15px;
                    line-height: 1.7;
                    color: #334155;
                  "
                >
                  Your password was changed on
                  <strong><%= changedAt %></strong>.
                </p>
                <p
                  style="
                    margin: 0 0 14px;
                    font-size: 15px;
                    line-height: 1.7;
                    color: #334155;
                  "
                >
                  If this was not you, please contact support immediately at
                  <strong><%= supportEmail %></strong>.
                </p>
              </td>
            </tr>
            <tr>
              <td
                style="
                  padding: 16px 28px 24px;
                  font-size: 12px;
                  color: #64748b;
                  border-top: 1px solid #e2e8f0;
                "
              >
                <p style="margin: 0">
                  This is a security notification from Niramoy.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
