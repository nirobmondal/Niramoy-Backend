<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Continue with Google</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #ecfeff, #f8fafc);
        font-family: Arial, sans-serif;
        color: #0f172a;
      }

      .card {
        width: min(90vw, 420px);
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 28px;
        box-shadow: 0 10px 30px rgba(2, 6, 23, 0.08);
        text-align: center;
      }

      .loader {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 4px solid #cbd5e1;
        border-top-color: #0f766e;
        margin: 0 auto 16px;
        animation: spin 0.9s linear infinite;
      }

      .button {
        display: inline-block;
        margin-top: 14px;
        background: #0f766e;
        color: white;
        text-decoration: none;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 8px;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="loader"></div>
      <h2 style="margin: 0 0 8px">Redirecting to Google</h2>
      <p style="margin: 0; color: #475569">
        You are being redirected for secure sign in.
      </p>
      <a id="manual-link" class="button" href="#">Continue manually</a>
    </div>

    <script>
      const authUrl = "<%- betterAuthUrl %>";
      const callbackUrl = "<%- callbackURL %>";
      const socialLoginUrl = `${authUrl}/api/auth/sign-in/social?provider=google&callbackURL=${encodeURIComponent(callbackUrl)}`;

      document
        .getElementById("manual-link")
        .setAttribute("href", socialLoginUrl);

      setTimeout(() => {
        window.location.href = socialLoginUrl;
      }, 400);
    </script>
  </body>
</html>
