model SellerMedicine {
  id         String @id @default(cuid())
  sellerId   String
  medicineId String

  price Decimal @db.Decimal(10, 2)
  stock Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller   Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([sellerId, medicineId])
  @@index([sellerId], name: "seller_medicine_seller_id_idx")
  @@index([medicineId], name: "seller_medicine_medicine_id_idx")
  @@index([price], name: "seller_medicine_price_idx")
  @@index([stock], name: "seller_medicine_stock_idx")
  @@map("seller_medicines")
}
