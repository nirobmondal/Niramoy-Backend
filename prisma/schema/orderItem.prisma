model OrderItem {
  id            String   @id @default(uuid(7))
  sellerOrderId String
  medicineId    String
  quantity      Int
  price         Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  medicine    Medicine    @relation(fields: [medicineId], references: [id])
  sellerOrder SellerOrder @relation(fields: [sellerOrderId], references: [id])

  @@unique([sellerOrderId, medicineId])
  @@index([sellerOrderId], name: "order_item_seller_order_id_idx")
  @@index([medicineId], name: "order_item_medicine_id_idx")
  @@map("order_items")
}
