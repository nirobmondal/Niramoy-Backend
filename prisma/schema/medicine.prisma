model Medicine {
  id          String  @id @default(uuid(7))
  name        String  @unique
  description String?

  strength       String?
  dosageForm     String?
  imageUrl       String?
  isAvailable    Boolean @default(true)
  categoryId     String
  manufacturerId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  manufacturer    Manufacturer     @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  sellerMedicines SellerMedicine[]
  reviews         Review[]

  @@index([name], name: "medicine_name_idx")
  @@index([categoryId], name: "medicine_category_id_idx")
  @@index([manufacturerId], name: "medicine_manufacturer_id_idx")
  @@index([isAvailable], name: "medicine_is_available_idx")
  @@map("medicines")
}
