model Medicine {
  id          String  @id @default(uuid(7))
  name        String
  description String?

  strength       String?
  dosageForm     String?
  imageUrl       String?
  price          Decimal @default(0.0)
  stock          Int     @default(0)
  isAvailable    Boolean @default(true)
  categoryId     String
  manufacturerId String
  sellerId       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category     Category     @relation(fields: [categoryId], references: [id])
  manufacturer Manufacturer @relation(fields: [manufacturerId], references: [id])
  seller       Seller       @relation(fields: [sellerId], references: [id])
  orderItems   OrderItem[]
  cartItems    CartItem[]
  reviews      Review[]

  @@index([name], name: "medicine_name_idx")
  @@index([categoryId], name: "medicine_category_id_idx")
  @@index([manufacturerId], name: "medicine_manufacturer_id_idx")
  @@index([isAvailable], name: "medicine_is_available_idx")
  @@map("medicines")
}
